# Credentials: exclude all secret files, but track the index
.credentials/*.txt
.credentials/*.json
# Re-include the index (metadata only, no secret values)
!.credentials/CREDENTIALS_INDEX.json

# Runtime/state/log noise
.cache/
.state/
.reminder-state/
logs/*.log
tmp/
tmp_*.txt
consolidation-input.txt
auto,

# Python cache
__pycache__/
*.pyc

scripts/google-drive-oauth.py
.google-drive-sa.json
outputs/

{
  "mcpServers": {
    "zapier-mcp": {
      "baseUrl": "${ZAPIER_MCP_BASE_URL}"
    },
    "google-workspace": {
      "command": "/home/claw/.local/bin/workspace-mcp",
      "args": [
        "--single-user",
        "--tools",
        "drive",
        "gmail",
        "docs",
        "sheets",
        "--read-only"
      ],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "${GOOGLE_OAUTH_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "${GOOGLE_OAUTH_CLIENT_SECRET}"
      }
    },
    "google-workspace-http": {
      "baseUrl": "http://127.0.0.1:8000/mcp",
      "auth": "oauth"
    }
  },
  "imports": []
}
